# Global Trello Credentials
TRELLO_KEY=your_trello_api_key
TRELLO_SECRET=your_trello_api_secret
TRELLO_CALLBACK_URL=https://your-server.com/webhook

# Global Junie Credentials
JUNIE_API_KEY=your_junie_api_key

# Bridge Configuration
PORT=3000
DRY_RUN=false

# Git Configuration
# Recommended for private SSH repositories: start ssh-agent on the host and run ssh-add ~/.ssh/id_ed25519 before starting Docker.
# SSH_AUTH_SOCK is normally exported automatically by ssh-agent and forwarded by docker-compose.yml.
# Optional: customize SSH behavior, for example to select a specific key or known_hosts policy.
GIT_SSH_COMMAND=ssh -i /root/.ssh/id_ed25519 -o IdentitiesOnly=yes
GIT_COMMAND_TIMEOUT_MS=120000
GIT_USER_NAME=Junie Bridge
GIT_USER_EMAIL=junie-bridge@example.com
